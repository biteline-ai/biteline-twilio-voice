# Biteline Voice Server — environment variables
# Copy to .env and fill in real values.  NEVER commit .env.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=6501
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://biteline:password@localhost:5432/biteline

# ── Redis (optional — enables cross-instance session sharing + call limiting) ─
# When not set, falls back to in-memory store (single-instance only)
REDIS_URL=redis://localhost:6379

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...          # Gemini Live
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
XAI_API_KEY=xai-...

# ── STT / TTS ─────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...
CARTESIA_API_KEY=...

# ── Knowledge Nexus (optional RAG integration) ────────────────────────────────
KNOWLEDGE_NEXUS_URL=http://localhost:6510
KNOWLEDGE_NEXUS_API_KEY=...
